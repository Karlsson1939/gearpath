-- GearPath
-- Data/GearPath_Stats.lua - Stat priorities, gems, enchants, consumables
-- AUTO-GENERATED by companion app. Do not edit manually.
-- Run: cd companion && go run . generate-guide
-- Last generated: {{.Generated}}
--
-- Consumables for Blood DK (Deathbringer vs San'layn) and Enhancement Shaman
-- (Stormbringer vs Totemic) are approximate per hero talent — both hero talents
-- see the first-mentioned recommendation on the page. See Icy Veins for
-- hero-specific consumable differences. Per-hero consumable parsing deferred
-- to v0.3.1+.
--
-- Holy Paladin Lightsmith weapon oil: both hero talents show Thalassian Phoenix
-- Oil. Lightsmith users who use Rite of Sanctification may not need it.

GearPath.GuideData = {}
{{range $group := .Groups}}
GearPath.GuideData["{{$group.Class}}"] = GearPath.GuideData["{{$group.Class}}"] or {}
GearPath.GuideData["{{$group.Class}}"]["{{$group.Spec}}"] = {}
{{range $entry := $group.Entries}}
-- {{$group.Class}} {{$group.Spec}} [{{$entry.HeroKey}}] | Updated: {{$entry.Updated}}
GearPath.GuideData["{{$group.Class}}"]["{{$group.Spec}}"]["{{$entry.HeroKey}}"] = {

    Stats = {
        format  = "{{$entry.Stats.Format}}",
        ordered = { {{range $entry.Stats.Ordered}}"{{.}}", {{end}} },{{if $entry.Stats.Percentage}}
        percentage = {
{{range $entry.Stats.Percentage}}            { stat = "{{.Stat}}", pct = {{.Pct}} },
{{end}}        },{{end}}{{if $entry.Stats.Note}}
        note = "{{$entry.Stats.Note}}",{{end}}
    },

    Gems = {
{{range $entry.Gems}}        { name = "{{.Name}}" },
{{end}}    },

    Enchants = {
{{range $entry.Enchants}}        { slot = "{{.Slot}}", enchant = "{{.Enchant}}" },
{{end}}    },

    Consumables = {
        flask     = "{{$entry.Consumables.Flask}}",
        food      = "{{$entry.Consumables.Food}}",
        potion    = "{{$entry.Consumables.Potion}}",
        weaponOil = "{{$entry.Consumables.WeaponOil}}",
        augRune   = "{{$entry.Consumables.AugRune}}",
    },
}
{{end}}
{{end}}